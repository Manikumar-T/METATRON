# Database credentials
DB_HOST=mariadb
DB_USER=metatron
DB_PASSWORD=metatron_password
DB_NAME=metatron

# MariaDB root password (used only during container init)
MYSQL_ROOT_PASSWORD=rootpassword

# ───────────────────────────────────────────────────────
# LLM PROVIDER CONFIGURATION
# ───────────────────────────────────────────────────────

# Select LLM provider: "ollama" or "openai"
LLM_PROVIDER=ollama

# --- Ollama Configuration ---
# Ollama API endpoint (default: local Ollama)
OLLAMA_URL=http://localhost:11434/api/chat
# Ollama model name (must match the model in Ollama)
OLLAMA_MODEL=metatron-qwen

# --- OpenAI-Compatible Configuration ---
# Base URL for OpenAI or compatible API (e.g., vLLM, LM Studio, Anthropic)
OPENAI_BASE_URL=https://api.openai.com/v1
# Model name to use with the provider
OPENAI_MODEL=gpt-4o
# API key (required for OpenAI/Anthropic, may be optional for local servers)
OPENAI_API_KEY=your-api-key-here
